# Datos de conexión a la base de datos MySQL

DB_HOST=localhost
# Dirección donde vive el servidor de MySQL. "localhost" significa que corre en tu misma máquina.

DB_PORT=3306
# Puerto donde MySQL está escuchando conexiones. 3306 es el puerto por defecto de MySQL.

DB_USER=root
# Usuario con el que te conectas a la base de datos (en Laragon es "root").

DB_PASSWORD=
# Contraseña de ese usuario. Aquí está vacía porque en tu entorno local "root" no tiene contraseña.

DB_NAME=papeleria
# Nombre de la base de datos a la que te vas a conectar (en este caso un proyecto de prueba "papeleria").


# Credencial para conectarte a la IA (Groq)

GROQ_API_KEY=tu_nueva_key_aqui
# La API key que usa tu código para autenticarse con Groq y poder mandar preguntas al modelo de IA.